# ============ Shared Infrastructure ============
NODE_ENV=development

# Postgres (one logical server, db-per-service)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=ecom
POSTGRES_PASSWORD=ecom_secret

# Per-service databases (DB-per-service pattern)
USER_DATABASE_URL=postgresql://ecom:ecom_secret@postgres:5432/user_db?schema=public
BOOKING_DATABASE_URL=postgresql://ecom:ecom_secret@postgres:5432/booking_db?schema=public
PAYMENT_DATABASE_URL=postgresql://ecom:ecom_secret@postgres:5432/payment_db?schema=public

# Redis (cache, distributed lock, idempotency)
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=ecom

# Elasticsearch
ELASTICSEARCH_NODE=http://elasticsearch:9200

# Service ports
GATEWAY_PORT=3000
USER_SERVICE_PORT=3001
BOOKING_SERVICE_PORT=3002
PAYMENT_SERVICE_PORT=3003
SEARCH_SERVICE_PORT=3004

# Internal service URLs (used by API gateway)
USER_SERVICE_URL=http://user-service:3001
BOOKING_SERVICE_URL=http://booking-service:3002
PAYMENT_SERVICE_URL=http://payment-service:3003
SEARCH_SERVICE_URL=http://search-service:3004

# Auth
JWT_SECRET=super_secret_change_me
JWT_EXPIRES_IN=15m

# Payment provider sandbox keys (mock)
STRIPE_API_KEY=sk_test_mock
RAZORPAY_KEY_ID=rzp_test_mock
RAZORPAY_KEY_SECRET=rzp_secret_mock
PAYPAL_CLIENT_ID=paypal_mock
