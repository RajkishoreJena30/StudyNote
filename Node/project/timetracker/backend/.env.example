# ----------------------------------------------------------------------------
# Shared
# ----------------------------------------------------------------------------
NODE_ENV=development

# ----------------------------------------------------------------------------
# Database (shared Postgres instance)
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://timetracker:timetracker@localhost:5432/timetracker?schema=public

# ----------------------------------------------------------------------------
# Redis (caching + rate limiting)
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# ----------------------------------------------------------------------------
# JWT
# ----------------------------------------------------------------------------
JWT_ACCESS_SECRET=super-secret-access-key-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=super-secret-refresh-key-change-me
JWT_REFRESH_EXPIRES_IN=7d

# ----------------------------------------------------------------------------
# API Gateway
# ----------------------------------------------------------------------------
GATEWAY_PORT=3000
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8080

# ----------------------------------------------------------------------------
# Microservice TCP hosts/ports (used by the gateway clients + each service)
# ----------------------------------------------------------------------------
AUTH_SERVICE_HOST=localhost
AUTH_SERVICE_PORT=4001

SUBSCRIPTION_SERVICE_HOST=localhost
SUBSCRIPTION_SERVICE_PORT=4002

PRODUCTIVITY_SERVICE_HOST=localhost
PRODUCTIVITY_SERVICE_PORT=4003
