{
  "name": "timetracker-backend",
  "version": "1.0.0",
  "description": "TimeTracker — NestJS microservices backend (API Gateway + TCP services)",
  "author": "TimeTracker Team",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build api-gateway && nest build auth-service && nest build subscription-service && nest build productivity-service",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start:gateway": "nest start api-gateway --watch",
    "start:auth": "nest start auth-service --watch",
    "start:subscription": "nest start subscription-service --watch",
    "start:productivity": "nest start productivity-service --watch",
    "start:prod:gateway": "node dist/apps/api-gateway/main",
    "start:prod:auth": "node dist/apps/auth-service/main",
    "start:prod:subscription": "node dist/apps/subscription-service/main",
    "start:prod:productivity": "node dist/apps/productivity-service/main",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "prisma:generate": "prisma generate --schema=libs/prisma/src/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=libs/prisma/src/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=libs/prisma/src/schema.prisma",
    "prisma:seed": "ts-node libs/prisma/src/seed.ts",
    "prisma:studio": "prisma studio --schema=libs/prisma/src/schema.prisma"
  },
  "prisma": {
    "seed": "ts-node libs/prisma/src/seed.ts"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^2.3.0",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.4.4",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/swagger": "^8.0.1",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/client": "^5.20.0",
    "bcrypt": "^5.1.1",
    "cache-manager": "^5.7.6",
    "cache-manager-ioredis-yet": "^2.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.4",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.4",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "prisma": "^5.20.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2"
  }
}
